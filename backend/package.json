{
  "name": "nerolis-lab-backend",
  "version": "2.7.1",
  "private": true,
  "main": "app.ts",
  "type": "module",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "tsc --project tsconfig.build.json && tsc-alias && tsoa spec && npm run _compile",
    "postbuild": "copyfiles -u 1 src/**/*.html src/**/*.css src/**/**/*.json src/**/*.png src/assets/* src/assets/**/* ../CHANGELOG.md dist/",
    "test": "vitest --run --coverage",
    "test-watch": "vitest --watch",
    "benchmark-set": "vitest run benchmark --mode benchmarking --update",
    "benchmark-test": "vitest run benchmark --mode benchmarking",
    "_compile": "bun x tsc --noEmit",
    "start": "npm run build && node ./dist/app.js",
    "dev": "bun i && bun --watch src/app.ts",
    "type-watch": "bun x tsc --noEmit --watch"
  },
  "files": ["dist"],
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.5.2",
    "@types/seedrandom": "^3.0.8",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.4",
    "copyfiles": "^2.4.1",
    "rimraf": "^6.1.3",
    "sqlite3": "^6.0.1",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "typescript": "^6.0.2",
    "vimic": "^1.2.4",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.49",
    "axios": "^1.15.0",
    "cookie-parser": "~1.4.7",
    "cors": "^2.8.6",
    "discord-oauth2": "^2.12.1",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "google-auth-library": "^10.6.2",
    "knex": "^3.2.9",
    "morgan": "~1.10.1",
    "mysql2": "~3.21.0",
    "seedrandom": "^3.0.5",
    "sleepapi-common": "file:../common",
    "swagger-ui-express": "^5.0.1",
    "tsoa": "^6.6.0",
    "workerpool": "^10.0.1"
  },
  "bundleDependencies": ["sleepapi-common"]
}
